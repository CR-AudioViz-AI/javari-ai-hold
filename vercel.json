{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "enabled": true,
    "autoAlias": false,
    "silent": false,
    "autoJobCancelation": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://craudiovizai.com https://www.craudiovizai.com;"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/autonomy/loop",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/autonomy/scan",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/autonomy/pr-workflow",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/autonomy/pr-merge",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/alerts-check",
      "schedule": "*/5 * * * *"
    }
  ]
}
